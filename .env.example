# GitHub personal access token (classic or fine-grained, public read is enough).
# Optional for dev (REST works unauthenticated at 60 req/hr), but:
#   - raises REST rate limit to 5000 req/hr
#   - REQUIRED for the contribution count (GraphQL)
GITHUB_TOKEN=

# Anthropic API key for the "THE ORACLE SAYS" flavor text.
# Optional — without it the card falls back to the user's GitHub bio.
ANTHROPIC_API_KEY=

# Public site name shown in the card footer.
NEXT_PUBLIC_SITE_NAME=GITHUB-POKEMON.COM
